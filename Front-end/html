<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>jp ceo y nacho disque backend</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="diseño.css">
</head>
<body>
    <div class="contenedor">
        <div class="form-log_in">
            <form action="">
                <h2>Iniciar sesion</h2>
                <div class="input-box">
                    <input type="text" placeholder="Nombre" required>
                    <i class="bx bxs-user"></i>
                </div>
                <div class="input-box">
                    <input type="text" placeholder="Contraseña" required>
                    <i class="bx bxs-lock-alt"></i>
                </div>
                
                <div class="forgot-passw">
                    <a href="#">¿Olvidaste tu Contraseña?</a>
                </div>
                <button type="submit" class="btn">Iniciar sesion</button>
                <p>o inicia sesion con</p>
                <div class="social-icons">
                    <a href="#"><i class="bx bxl-google"></i></a>
                    <a href="#"><i class="bx bxl-facebook"></i></a>
                </div>
            </form>
        </div>

        <div class="form-signup">
            <form action="">
                <h2>Registrarse</h2>
                <div class="input-box">
                    <input type="text" placeholder="Nombre" required>
                    <i class="bx bxs-user"></i>
                </div>
                <div class="input-box">
                    <input type="email" placeholder="Email" required>
                    <i class="bx bxs-envelope"></i>
                </div>
                <div class="input-box">
                    <input type="text" placeholder="Contraseña" required>
                    <i class="bx bxs-lock-alt"></i>
                </div>
                
                <button type="submit" class="btn">Registrarse</button>
                <p>o registrate con</p>
                <div class="social-icons">
                    <a href="#"><i class="bx bxl-google"></i></a>
                    <a href="#"><i class="bx bxl-facebook"></i></a>
                </div>
            </form>
        </div>

        <div class="toggle-box">
            <div class="toggle-panel toggle-left">
                <h2>Hola bienvenido</h2>
                <p>¿No tines una cuenta?</p>
                <button class="btn register-btn">Registrarse</button>
            </div>

            <div class="toggle-panel toggle-right">
                <h2>¡Ya estás aqui de nuevo¡</h2>
                <p>¿Ya tines una cuenta?</p>
                <button class="btn login-btn">Log in</button>
            </div>
        </div>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
